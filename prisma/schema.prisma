generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum BlockCategory {
  SOLIDARITY
  PREMIUM
  GOLD
  GRAND_CENTER
}

enum BlockStatus {
  AVAILABLE
  RESERVED
  SOLD
  LOCKED
  BLOCKED
}

enum PlacementKind {
  SOLIDARITY
  PREMIUM
  GOLD
  GRAND_CENTER
}

enum PlacementStatus {
  ACTIVE
  IMAGE_BLOCKED
  BANNED
  REMOVED
}

enum ReviewStatus {
  PUBLISHED_NOT_REVIEWED
  APPROVED
  CHANGES_REQUESTED
  HIDDEN_BY_ADMIN
}

enum TransactionKind {
  SOLIDARITY
  PREMIUM
  GOLD
  GRAND_CENTER
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum ReportStatus {
  OPEN
  REVIEWING
  WARNED
  RESOLVED
  DISMISSED
  BLOCKED
  BANNED
}

enum EditRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum DisputeStatus {
  OPEN
  REVIEWING
  WON
  LOST
  CLOSED_EXCEPTION
}

enum AdminActionType {
  WARN
  BLOCK_IMAGE
  BLOCK_LINK
  HIDE_DESCRIPTION
  HIDE_PUBLIC_NAME
  RELEASE_BLOCK
  BAN_USER
  RESOLVE_REPORT
  REJECT_REPORT
  RESTORE_CONTENT
  APPROVE_CONTENT
  APPROVE_EDIT
  REJECT_EDIT
  OPEN_DISPUTE
  CLOSE_DISPUTE
  BAN_RELEASE
}

enum LedgerRecipient {
  CREATOR
  HOSPITAL
}

enum LedgerStatus {
  PENDING
  PAID
  CANCELLED
}

model User {
  id                 String   @id @default(cuid())
  name               String
  publicName         String?
  email              String?  @unique
  whatsapp           String?
  cpfHash            String?
  cpfLast4           String?
  passwordHash       String?
  role               UserRole @default(USER)

  totalApprovedCents Int      @default(0)
  isBanned           Boolean  @default(false)
  isTest             Boolean  @default(false)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  transactions       Transaction[]
  placements         Placement[]
  ownedBlocks        Block[]       @relation("BlockOwner")
  editRequests       ContentEditRequest[]
  adminActions       AdminAction[] @relation("AdminActions")

  @@index([role])
  @@index([totalApprovedCents])
}

model Block {
  id                   String        @id @default(cuid())
  gridX                Int
  gridY                Int
  category             BlockCategory
  status               BlockStatus   @default(AVAILABLE)
  available            Boolean       @default(true)
  priceCents           Int

  ownerId              String?
  owner                User?         @relation("BlockOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  placementId          String?
  placement            Placement?    @relation(fields: [placementId], references: [id], onDelete: SetNull)

  currentTransactionId String?
  currentTransaction   Transaction?  @relation("CurrentTransactionBlocks", fields: [currentTransactionId], references: [id], onDelete: SetNull)

  reservationToken     String?
  reservedUntil        DateTime?

  reports              Report[]
  transactionItems     TransactionBlock[]
  adminActions         AdminAction[]

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@unique([gridX, gridY])
  @@index([category, status, available])
  @@index([ownerId])
  @@index([placementId])
  @@index([reservedUntil])
}

model Placement {
  id                String          @id @default(cuid())
  kind              PlacementKind
  status            PlacementStatus @default(ACTIVE)
  reviewStatus      ReviewStatus    @default(PUBLISHED_NOT_REVIEWED)

  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactionId     String          @unique
  transaction       Transaction     @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  title             String?
  description       String?
  imageUrl          String?
  imageStorageKey   String?
  placeholderReason String?
  redirectUrl       String?
  linkDisabled      Boolean         @default(false)

  displayName       String?
  fillColor         String?
  textLabel         String?

  originX           Int?
  originY           Int?
  widthBlocks       Int?
  heightBlocks      Int?

  blocks            Block[]
  reports           Report[]
  editRequests      ContentEditRequest[]

  isTest            Boolean         @default(false)

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([kind, status])
  @@index([reviewStatus, createdAt])
  @@index([userId])
}

model Transaction {
  id                   String            @id @default(cuid())
  kind                 TransactionKind
  status               TransactionStatus @default(PENDING)

  userId               String
  user                 User              @relation(fields: [userId], references: [id], onDelete: Restrict)

  subtotalCents        Int
  operatorFeeCents     Int
  totalPaidCents       Int

  creatorShareCents    Int
  hospitalShareCents   Int

  checkoutWhatsapp     String?
  checkoutCpfHash      String?
  checkoutCpfLast4     String?
  termsAcceptedAt      DateTime?
  termsVersion         String?

  managementTokenHash  String?           @unique
  managementTokenCreatedAt DateTime?

  placementTitle       String?
  placementDescription String?           @db.Text
  placementRedirectUrl String?
  placementImageUrl    String?
  placementFillColor   String?

  mpPaymentId          String?           @unique
  mpExternalReference  String            @unique
  mpStatus             String?
  mpStatusDetail       String?

  pixQrCode            String?
  pixQrCodeBase64      String?           @db.Text
  pixCopyPaste         String?           @db.Text

  expiresAt            DateTime?
  approvedAt           DateTime?
  paidAt               DateTime?

  items                TransactionBlock[]
  currentBlocks        Block[]           @relation("CurrentTransactionBlocks")
  placement            Placement?
  ledgerEntries        DistributionLedger[]
  disputeCases         DisputeCase[]
  webhookEvents        PaymentWebhookEvent[]

  isTest               Boolean           @default(false)

  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([userId, status])
}

model TransactionBlock {
  transactionId String
  blockId       String

  gridX         Int
  gridY         Int
  category      BlockCategory
  priceCents    Int

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  block         Block       @relation(fields: [blockId], references: [id], onDelete: Restrict)

  @@id([transactionId, blockId])
  @@index([blockId])
  @@index([gridX, gridY])
}

model Report {
  id              String       @id @default(cuid())
  blockId         String
  block           Block        @relation(fields: [blockId], references: [id], onDelete: Cascade)

  placementId     String?
  placement       Placement?   @relation(fields: [placementId], references: [id], onDelete: SetNull)

  reporterEmail   String?
  reporterIpHash  String?

  reason          String       @db.Text
  status          ReportStatus @default(OPEN)

  actions         AdminAction[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status, createdAt])
  @@index([blockId])
}

model ContentEditRequest {
  id                    String            @id @default(cuid())
  placementId           String
  placement             Placement         @relation(fields: [placementId], references: [id], onDelete: Cascade)

  userId                String
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  reason                String            @db.Text
  status                EditRequestStatus @default(PENDING)

  requestedTitle        String?
  requestedDescription  String?           @db.Text
  requestedImageUrl     String?
  requestedRedirectUrl  String?
  requestedDisplayName  String?
  requestedTextLabel    String?

  reviewedByAdminId     String?
  reviewedAt            DateTime?
  adminNote             String?           @db.Text

  actions               AdminAction[]

  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([placementId])
  @@index([userId])
}

model DisputeCase {
  id             String        @id @default(cuid())

  transactionId  String
  transaction    Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  status         DisputeStatus @default(OPEN)
  reason         String        @db.Text
  internalNote   String?       @db.Text
  externalRef    String?
  openedAt       DateTime      @default(now())
  closedAt       DateTime?

  actions        AdminAction[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([transactionId])
}

model AdminAction {
  id            String          @id @default(cuid())
  type          AdminActionType

  reportId      String?
  report        Report?         @relation(fields: [reportId], references: [id], onDelete: SetNull)

  blockId       String?
  block         Block?          @relation(fields: [blockId], references: [id], onDelete: SetNull)

  placementId   String?

  editRequestId String?
  editRequest   ContentEditRequest? @relation(fields: [editRequestId], references: [id], onDelete: SetNull)

  disputeCaseId String?
  disputeCase   DisputeCase?    @relation(fields: [disputeCaseId], references: [id], onDelete: SetNull)

  adminId       String
  admin         User            @relation("AdminActions", fields: [adminId], references: [id], onDelete: Restrict)

  note          String?         @db.Text

  createdAt     DateTime        @default(now())

  @@index([type, createdAt])
  @@index([adminId])
  @@index([placementId])
  @@index([editRequestId])
  @@index([disputeCaseId])
}

model PaymentWebhookEvent {
  id             String       @id @default(cuid())
  eventId        String?
  eventType      String?
  paymentId      String?
  payload        Json?
  previousStatus String?
  newStatus      String?
  processed      Boolean      @default(false)
  ignored        Boolean      @default(false)
  error          String?      @db.Text

  transactionId  String?
  transaction    Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  receivedAt     DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([paymentId])
  @@index([eventType, receivedAt])
  @@index([processed, ignored])
  @@index([transactionId])
}

model DistributionLedger {
  id            String          @id @default(cuid())

  transactionId String
  transaction   Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  recipient     LedgerRecipient
  amountCents   Int
  status        LedgerStatus    @default(PENDING)

  proofUrl      String?
  paidAt        DateTime?

  createdAt     DateTime        @default(now())

  @@index([recipient, status])
  @@index([transactionId])
}
